{
  "$schema": "https://react.doctor/schema/config.json",
  "rules": {
    "react-doctor/use-lazy-motion": "off",
    "react-doctor/no-giant-component": "off",
    "react-doctor/no-array-index-as-key": "off",
    "react-doctor/no-inline-exhaustive-style": "off",
    "react-doctor/no-fetch-in-effect": "off",
    "react-doctor/nextjs-no-client-fetch-for-server-data": "off",
    "react-doctor/no-adjust-state-on-prop-change": "off",
    "react-doctor/nextjs-no-client-side-redirect": "off",
    "react-doctor/effect-needs-cleanup": "off",
    "react-doctor/exhaustive-deps": "off",
    "react-doctor/prefer-dynamic-import": "off",
    "react-doctor/public-env-secret-name": "off",
    "react-doctor/no-locale-format-in-render": "off",
    "react-doctor/no-layout-property-animation": "off",
    "react-doctor/no-transition-all": "off",
    "react-doctor/no-nested-component-definition": "off",
    "react-doctor/no-set-state-after-await-in-effect": "off",
    "react-doctor/no-placeholder-only-field": "off",
    "react-doctor/nextjs-no-a-element": "off",
    "react-doctor/nextjs-no-img-element": "off",
    "react-doctor/no-tiny-text": "off",
    "react-doctor/button-has-type": "off",
    "react-doctor/click-events-have-key-events": "off",
    "react-doctor/no-static-element-interactions": "off",
    "react-doctor/control-has-associated-label": "off",
