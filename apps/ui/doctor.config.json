    "react-doctor/no-autofocus": "off",
    "react-doctor/rendering-hydration-no-flicker": "off",
    "react-doctor/no-call-component-as-function": "off",
    "react-doctor/no-async-event-handler-without-reentry-guard": "off",
    "react-doctor/effect-raf-loop-needs-cancel": "off",
    "react-doctor/iframe-missing-sandbox": "off",
    "react-doctor/window-open-without-noopener": "off"
