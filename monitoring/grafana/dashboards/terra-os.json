{
  "title": "Terra.OS API Dashboard",
  "uid": "terra-os-api",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Request Duration P95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 {{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Engine Runs Total",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(terra_engine_runs_total[5m])",
          "legendFormat": "{{tenant_id}} {{status}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Engine Run Latency P95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(terra_engine_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 {{tenant_id}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Tenants",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "terra_active_tenants",
          "legendFormat": "Active Tenants"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "DB Pool Size",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "terra_db_pool_size",
          "legendFormat": "Pool Size"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "RFQ Sent Rate",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(terra_rfq_sent_total[5m])",
          "legendFormat": "{{tenant_id}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP 5xx Error Rate",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status_code=~\"5..\"}[5m])",
          "legendFormat": "5xx {{handler}}"
        }
      ]
    }
  ]
}
