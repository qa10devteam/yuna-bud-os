# ===== Terra.OS — .env.example (copy to .env; never commit .env) =====

# --- database (local, bundled in production) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=terraos
DB_USER=terraos
DB_PASSWORD=change_me

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0

# --- local AI (Ollama) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL_EXTRACT=qwen3:14b           # or qwen3:32b on 24GB GPU
OLLAMA_MODEL_VISION=gemma3:12b           # scanned-doc OCR (VERIFY exact tag)
OLLAMA_MODEL_EMBED=nomic-embed-text      # set document_chunk.embedding dim to match

# --- cloud AI (AWS Bedrock, Frankfurt) ---
BEDROCK_REGION=eu-central-1
BEDROCK_MODEL_DEFAULT=anthropic.claude-sonnet-4-6   # VERIFY model id/availability
BEDROCK_MODEL_LIGHT=anthropic.claude-haiku
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ENABLE_PROMPT_CACHING=true
ENABLE_BATCH=true

# --- tender sources (VERIFY all schemas/bases at build) ---
BZP_API_BASE=https://ezamowienia.gov.pl/mo-board/api/v1
TED_API_BASE=
BK_API_BASE=
BIP_ENABLED=false                        # Tier 2+

# --- email-broker (Tier 2+) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# --- messenger / maps / mobile (Tier 3) ---
MESSENGER_PROVIDER=whatsapp              # whatsapp|telegram
MESSENGER_TOKEN=
MAPS_API_KEY=
MOBILE_PUSH_PROVIDER=fcm

# --- tiering & guardrails ---
TIER=silnik                              # fundament|silnik|mozg
APPROVAL_REQUIRED=true                   # MUST stay true
COST_CAP_DAILY_PLN=50
SEED=42                                  # determinism for L2

# --- backup ---
BACKUP_PATH=/mnt/backup/terraos
BACKUP_CLOUD_ENCRYPTED=false
UPDATE_FEED_URL=
